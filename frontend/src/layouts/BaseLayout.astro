---
import "../styles/global.css";
// Importamos el Manager que centraliza los popups de Login y Settings
import ModalManager from "../components/modals/ModalManager";
const { title = "WELIKECHESS" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/w_king.svg" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" rel="stylesheet">

    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem("theme") || "dark";
        if (savedTheme === "dark") {
          document.documentElement.classList.add("dark-mode");
        }
        
        const savedSettings = localStorage.getItem("user_settings");
        if (savedSettings) {
          const parsed = JSON.parse(savedSettings);
          if (parsed.animations === false) {
            document.documentElement.classList.add('no-animations');
          }
        }
      })();
    </script>

    <title>{title}</title>
  </head>

  <body class="transition-colors duration-300">

    <nav class="fixed top-0 left-0 w-full h-16 md:h-20 bg-white/80 shadow-lg flex items-center px-4 md:px-10 z-50 backdrop-blur-md border-b border-gold/20">
      <div class="flex-1 flex justify-start">
        <button id="menuBtn" class="text-2xl md:text-3xl focus:outline-none cursor-pointer hover:rotate-12 transition-transform">
          <span class="hamburger-icon">☰</span>
        </button>
      </div>

      <div class="flex-grow text-center">
        <a href="/" class="inline-block group">
          <h1 class="text-4xl md:text-5xl font-black tracking-tight" style="font-family: 'Cinzel', serif;">
            <span class="bg-gradient-to-b from-[#fefcf0] via-[#d4af37] to-[#996515] bg-clip-text text-transparent">WELIKE</span><span class="text-white">CHESS</span>
          </h1>
          <div class="h-[2px] w-0 group-hover:w-full bg-gradient-to-r from-transparent via-[#d4af37] to-transparent transition-all duration-500 opacity-50"></div>
        </a>
      </div>

      <div class="flex-1 flex justify-end items-center">
        <button 
          onclick="window.dispatchEvent(new CustomEvent('open-login'))"
          class="group relative overflow-hidden px-6 py-2 border border-[#d4af37]/40 rounded-full transition-all hover:border-[#d4af37] active:scale-95 cursor-pointer"
          style="font-family: 'Cinzel', serif;"
        >
          <span class="relative z-10 text-[#d4af37] text-[10px] md:text-xs font-black uppercase tracking-[0.3em] group-hover:text-black transition-colors duration-300">
            Acceso
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-[#8a6d1d] to-[#d4af37] translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
        </button>
      </div>
    </nav>

    <div id="sideMenu"
      class="fixed top-0 left-0 h-full w-full sm:w-72 bg-white shadow-2xl transform -translate-x-full transition-transform duration-500 z-50 border-r border-gold/30">

      <div class="p-6 md:p-8 flex flex-col h-full">
        <h2 class="text-3xl md:text-4xl font-black mb-6 md:mb-8 italic" style="font-family: 'Cinzel', serif; color: #d4af37;">
          MENÚ
        </h2>

        <ul class="flex flex-col gap-4 md:gap-5 text-lg md:text-xl overflow-y-auto flex-grow" style="font-family: 'Cinzel', serif;">
          <li><a href="/" class="menu-link">HOME</a></li>
          <li><a href="/play-online" class="menu-link">JUGAR ONLINE</a></li>
          <li><a href="/play-ia" class="menu-link">JUGAR VS IA</a></li>
          <li><a href="/play-local" class="menu-link">PARTIDA LOCAL</a></li>
          <li><a href="/puzzles" class="menu-link">PUZZLES</a></li>
          <li><a href="/ranking" class="menu-link">RANKING</a></li>
          <li><a href="/friends" class="menu-link">AMIGOS</a></li>
          <li>
            <button 
              onclick="window.dispatchEvent(new CustomEvent('open-history'))" 
              class="menu-link w-full text-left uppercase cursor-pointer"
            >
              Historial
            </button>
          </li>
          <li><a href="/profile" class="menu-link">PERFIL</a></li>
        </ul>

        <div class="pt-6 mt-auto border-t border-gold/10">
          <div 
            onclick="
              const sideMenu = document.getElementById('sideMenu');
              const menuOverlay = document.getElementById('menuOverlay');
              if (sideMenu) sideMenu.classList.add('-translate-x-full');
              if (menuOverlay) menuOverlay.classList.add('hidden');
              window.dispatchEvent(new CustomEvent('open-settings'));
            " 
            class="settings-container group flex items-center gap-4 cursor-pointer"
          >
            <img src="/assets/gear.png" class="w-10 h-10 md:w-14 md:h-14 settings-icon" alt="Settings" />
            <span class="font-bold tracking-widest text-[#d4af37] opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity" style="font-family: 'Cinzel', serif;">
              AJUSTES
            </span>
          </div>
        </div>
      </div>
    </div>

    <div id="menuOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm hidden z-40"></div>

    <main class="pt-20 md:pt-28 max-w-none mx-auto px-4 min-h-screen">
      <slot />
    </main>

    <ModalManager client:load />

    <script>
      import "../scripts/theme.ts";
      import "../scripts/layout.ts";
    </script>

  </body>
</html>

<style is:global>
  :root { --bg-card: #ffffff; --bg-panel: #f8f8f8; --text-main: #1a1a1a; }
  .dark-mode { --bg-card: #0a0a0a; --bg-panel: #141414; --text-main: #e0e0e0; }

  .no-animations, .no-animations * {
    transition: none !important;
    animation: none !important;
  }

  body { background-color: var(--bg-panel); color: var(--text-main); overflow-x: hidden; }
  nav { background-color: var(--bg-card); transition: all 0.4s ease; }
  #sideMenu { background: linear-gradient(180deg, var(--bg-panel) 0%, #0a0a0a 100%); }
  
  .menu-link { 
    color: var(--text-main); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
    display: block; position: relative;
  }
  .menu-link:hover { color: #ffd700; padding-left: 15px; }

  .settings-icon { 
    filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.4)); 
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55); 
  }
  .settings-container:hover .settings-icon { transform: rotate(180deg) scale(1.1); }
</style>