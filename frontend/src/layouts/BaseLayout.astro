---
import "../styles/global.css";
const { title = "WELIKECHESS" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/w_king.svg" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" rel="stylesheet">

    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem("theme") || "dark";
        if (savedTheme === "dark") {
          document.documentElement.classList.add("dark-mode");
        }
      })();
    </script>

    <title>{title}</title>
  </head>

  <body class="transition-colors duration-300">

    <nav class="fixed top-0 left-0 w-full h-16 md:h-20 bg-white/80 shadow-lg flex items-center px-4 md:px-8 z-50 backdrop-blur-md border-b border-gold/20">
      <button id="menuBtn" class="text-2xl md:text-3xl focus:outline-none cursor-pointer hover:rotate-12 transition-transform z-50">
        <span class="hamburger-icon">☰</span>
      </button>

      <div class="flex-1 text-center">
        <a href="/" class="inline-block group">
          <h1
            id="navBrand"
            class="text-2xl sm:text-3xl md:text-5xl font-black tracking-[0.1em] md:tracking-[0.2em] 
                   bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
                   bg-clip-text text-transparent cursor-pointer 
                   transition-all duration-500 transform group-hover:scale-105"
            style="font-family: 'Cinzel', serif; filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.3));"
          >
            WELIKECHESS
          </h1>
          <div class="h-[2px] w-0 group-hover:w-full bg-gradient-to-r from-transparent via-[#d4af37] to-transparent transition-all duration-500 opacity-50"></div>
        </a>
      </div>
    </nav>

    <div id="sideMenu"
      class="fixed top-0 left-0 h-full w-full sm:w-72 bg-white shadow-2xl transform -translate-x-full transition-transform duration-500 z-50 border-r border-gold/30">

      <div class="p-6 md:p-8 flex flex-col h-full">
        <h2 class="text-3xl md:text-4xl font-black mb-6 md:mb-8 italic" style="font-family: 'Cinzel', serif; color: #d4af37;">
          MENÚ
        </h2>

        <ul class="flex flex-col gap-4 md:gap-5 text-lg md:text-xl overflow-y-auto flex-grow" style="font-family: 'Cinzel', serif;">
          <li><a href="/" class="menu-link">HOME</a></li>
          <li><a href="/play-online" class="menu-link">JUGAR ONLINE</a></li>
          <li><a href="/play-ia" class="menu-link">JUGAR VS IA</a></li>
          <li><a href="/play-local" class="menu-link">PARTIDA LOCAL</a></li>
          <li><a href="/puzzles" class="menu-link">PUZZLES</a></li>
          <li><a href="/ranking" class="menu-link">RANKING</a></li>
          <li><a href="/friends" class="menu-link">AMIGOS</a></li>
          <li><a href="/history" class="menu-link">HISTORIAL</a></li>
          <li><a href="/profile" class="menu-link">PERFIL</a></li>
        </ul>

        <div class="pt-6 mt-auto border-t border-gold/10">
            <a href="/settings" class="settings-container group flex items-center gap-4">
              <img src="/assets/gear.png" class="w-10 h-10 md:w-14 md:h-14 settings-icon" alt="Settings" />
              <span class="font-bold tracking-widest text-[#d4af37] opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity" style="font-family: 'Cinzel', serif;">AJUSTES</span>
            </a>
        </div>
      </div>
    </div>

    <div id="menuOverlay"
      class="fixed inset-0 bg-black/40 backdrop-blur-sm hidden z-40">
    </div>

    <main class="pt-20 md:pt-28 max-w-7xl mx-auto px-4 min-h-screen">
      <slot />
    </main>

    <script>
      import "../scripts/theme.ts";
      import "../scripts/layout.ts";
    </script>

  </body>
</html>

<style is:global>
  /* Se mantienen tus estilos base */
  :root {
    --bg-card: #ffffff;
    --bg-panel: #f8f8f8;
    --text-main: #1a1a1a;
  }

  .dark-mode {
    --bg-card: #0a0a0a;
    --bg-panel: #141414;
    --text-main: #e0e0e0;
  }

  body {
    background-color: var(--bg-panel);
    color: var(--text-main);
    /* Evita scroll horizontal accidental */
    overflow-x: hidden;
  }

  #navBrand {
    text-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
  }

  nav {
    background-color: var(--bg-card);
    transition: all 0.4s ease;
  }

  #sideMenu {
    background: linear-gradient(180deg, var(--bg-panel) 0%, #0a0a0a 100%);
  }

  .menu-link {
    position: relative;
    padding-left: 0;
    color: var(--text-main);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 1px;
    display: block;
  }

  .menu-link:hover {
    color: #ffd700;
    padding-left: 15px;
  }

  /* El subrayado solo en pantallas donde el hover tiene sentido */
  @media (min-width: 768px) {
    .menu-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 1px;
      background: #d4af37;
      transition: width 0.3s ease;
    }
    .menu-link:hover::after {
      width: 100%;
    }
  }

  .settings-icon {
    filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.4));
    transition: transform 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .settings-container:hover .settings-icon {
    transform: rotate(180deg) scale(1.1);
  }

  .dark-mode nav {
    background-color: rgba(10, 10, 10, 0.85);
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
  }

  .dark-mode .chessboard-63f59 {
      filter: brightness(0.8) contrast(1.2);
  }
</style>