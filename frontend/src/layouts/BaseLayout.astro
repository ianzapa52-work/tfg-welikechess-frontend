---
import "../styles/global.css";
const { title = "Chess Platform" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="/w_king.svg" />

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Marcellus&display=swap" rel="stylesheet">

    <title>{title}</title>
  </head>

  <body class="bg-gray-100 text-gray-900">

    <nav class="fixed top-0 left-0 w-full h-16 bg-white shadow-md flex items-center px-4 z-50">

      <button id="menuBtn" class="text-3xl focus:outline-none cursor-pointer">
        ☰
      </button>

      <div class="flex-1 text-center">
        <a href="/" class="inline-block">
          <h1
            id="navBrand"
            class="royal-brand text-3xl md:text-4xl font-bold tracking-widest 
                  bg-gradient-to-r from-[#5a3e1b] via-[#7a5528] to-[#4a2f14]
                  bg-clip-text text-transparent cursor-pointer transition-all duration-300"
            style="font-family: 'Cinzel', serif;"
          >
            WELIKECHESS
          </h1>
        </a>
      </div>

    </nav>

    <div id="sideMenu"
      class="fixed top-0 left-0 h-full w-64 bg-white shadow-xl transform -translate-x-full transition-transform duration-300 z-50">

      <div class="p-6">
        <h2 class="text-4xl font-bold mb-6" style="font-family: 'Cinzel', serif;">
          Menú
        </h2>

        <ul class="flex flex-col gap-4 text-2xl" style="font-family: 'Cinzel', serif;">
          <li><a href="/" class="menu-link">Home</a></li>
          <li><a href="/play-online" class="menu-link">Jugar Online</a></li>
          <li><a href="/play-ia" class="menu-link">Jugar VS IA</a></li>
          <li><a href="/play-local" class="menu-link">Partida Local</a></li>
          <li><a href="/puzzles" class="menu-link">Puzzles</a></li>
          <li><a href="/ranking" class="menu-link">Ranking</a></li>
          <li><a href="/friends" class="menu-link">Amigos</a></li>
          <li><a href="/history" class="menu-link">Historial</a></li>
          <li><a href="/profile" class="menu-link">Perfil</a></li>
        </ul>

        <a href="/settings"
          class="settings-icon cursor-pointer absolute bottom-8 left-4">
          <img src="/assets/gear.png" class="w-20 h-20" alt="Settings" />
        </a>
      </div>
    </div>

    <div id="menuOverlay"
      class="fixed inset-0 bg-black/10 backdrop-blur-xs hidden z-40"></div>

    <main class="pt-20 max-w-7xl mx-auto">
      <slot />
    </main>

    <script type="module" src="/src/scripts/layout.js"></script>

  </body>
</html>
