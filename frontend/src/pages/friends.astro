---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Amigos">

  <div class="friends-wrapper">

    <h1
      class="text-3xl sm:text-4xl md:text-6xl font-black mb-8 md:mb-12 text-center
            bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
            bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      AMIGOS
    </h1>

    <div class="friends-grid">

      <section class="friends-section col-online">
        <h2>En línea</h2>
        <div id="friendsOnlineList"></div>
      </section>

      <section class="friends-section col-requests">
        <h2>Solicitudes</h2>
        <div id="friendsRequestsList"></div>
      </section>

      <section class="friends-section col-all">
        <h2>Todos los amigos</h2>
        <div id="friendsAllList"></div>
      </section>

    </div>

  </div>

  <script>
    import "../scripts/friends.ts";
  </script>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Marcellus&display=swap');

  .friends-wrapper {
    width: 100%;
    padding: 1rem; /* Reducido para móviles */
    min-height: 100vh;
  }

  @media (min-width: 768px) {
    .friends-wrapper {
      padding: 2rem;
    }
  }

  /* --- GRID RESPONSIVO --- */
  .friends-grid {
    display: flex;
    flex-direction: column; /* Columna por defecto para móvil */
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    width: 100%; /* Ocupa todo el ancho en móvil */
    margin: 1rem auto;
  }

  /* Desktop: Volvemos a las 3 columnas */
  @media (min-width: 1250px) {
    .friends-grid {
      flex-direction: row;
      align-items: flex-start;
      gap: 2rem;
      width: max-content;
    }
    .col-online { width: 360px; }
    .col-requests { width: 420px; }
    .col-all { width: 420px; }
  }

  /* --- PANEL INDIVIDUAL --- */
  .friends-section {
    background: var(--bg-panel);
    border-radius: 18px;
    border: 2px solid var(--border-panel);
    backdrop-filter: blur(14px);
    padding: 1.2rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    font-family: 'Cinzel', serif;
    width: 100%; /* Full width en móvil */
    max-width: 500px; /* Pero no gigante */
    height: 450px; /* Un poco más corto en móvil */
    overflow-y: auto;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  @media (min-width: 1250px) {
    .friends-section {
      padding: 1.8rem;
      height: 650px;
    }
  }

  .friends-section:hover {
    transform: translateY(-5px);
    border-color: var(--color-gold);
  }

  /* Scrollbar personalizada */
  .friends-section::-webkit-scrollbar { width: 6px; }
  .friends-section::-webkit-scrollbar-thumb {
    background: #d4af37;
    border-radius: 10px;
  }

  .friends-section h2 {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 1.2rem;
    border-left: 4px solid var(--color-gold);
    padding-left: 10px;
  }

  /* --- TARJETA DE AMIGO (Global) --- */
  :global(.friend-card) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 12px;
    padding: 0.8rem;
    margin-bottom: 0.8rem;
    display: flex;
    flex-wrap: wrap; /* Permite que los botones bajen si no hay espacio */
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  /* --- BOTONES --- */
  :global(.friend-btn) {
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (max-width: 400px) {
    :global(.friend-card) {
      flex-direction: column;
      text-align: center;
    }
    :global(.friend-btn) {
      width: 100%;
    }
  }
</style>