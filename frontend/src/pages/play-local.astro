---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Local Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel players">
        <div class="player-box white">
          <div class="player-header"><span>♔ BLANCAS</span></div>
          <div id="captured-black" class="mini-captured"></div>
        </div>

        <div class="status-center">
          <div id="game-status">TURNO BLANCAS</div>
        </div>

        <div class="player-box black">
          <div class="player-header"><span>♚ NEGRAS</span></div>
          <div id="captured-white" class="mini-captured"></div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h"><span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span></div>
          <div class="board-flex">
            <div class="coords-v"><span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span></div>
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel history">
        <div class="history-card">
          <div class="history-header">HISTORIAL</div>
          <div class="history-scroll">
            <table>
              <tbody id="move-body"></tbody>
            </table>
          </div>
        </div>
        <button id="resetBtn" class="gold-btn">REINICIAR PARTIDA</button>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/play-local.ts";
  </script>
</BaseLayout>

<style is:global>
  body.is-dragging, body.is-dragging * {
    cursor: grabbing !important;
  }

  .main-screen {
    min-height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
    align-items: flex-start; 
    padding: 15px 10px;
    overflow-x: hidden;
  }

  .game-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    align-items: center;
  }

  @media (min-width: 1200px) {
    .game-wrapper {
      display: grid;
      grid-template-columns: 220px 720px 240px;
      gap: 40px;
      align-items: center;
      max-width: 1250px;
    }
    .main-screen { align-items: center; padding-top: 0; }
  }

  .side-panel { display: flex; flex-direction: column; gap: 15px; width: 100%; max-width: 500px; }

  .player-box, .history-card {
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(212, 175, 55, 0.4);
    border-radius: 4px;
    padding: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .players {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .status-center { grid-column: span 2; }

  @media (min-width: 1200px) {
    .players { display: flex; grid-template-columns: none; }
  }

  .player-header, .history-header {
    font-family: 'Cinzel', serif;
    color: #d4af37;
    font-size: 0.8rem;
    letter-spacing: 1px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    padding-bottom: 6px;
    margin-bottom: 8px;
    text-align: center;
  }

  .board-frame {
    background: rgba(0, 0, 0, 0.4);
    padding: 10px;
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.2);
    box-shadow: 0 0 40px rgba(0,0,0,0.8);
  }

  .compact-board {
    width: 88vw; 
    height: 88vw;
    max-width: 640px;
    max-height: 640px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    position: relative;
  }

  @media (min-width: 768px) {
    .board-frame { padding: 20px; }
    .compact-board { width: 550px; height: 550px; }
  }

  @media (min-width: 1200px) {
    .compact-board { width: 640px; height: 640px; }
  }

  .square {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .square.legal-move {
    box-shadow: inset 0 0 0 5px rgb(241, 209, 4); 
    cursor: pointer;
  }

  .piece {
    width: 90%;
    height: 90%;
    cursor: grab;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.6));
    touch-action: none;
    user-select: none;
    z-index: 5;
    transition: opacity 0.2s ease;
  }

  .piece.dragging-active {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 65px;
    height: 65px;
    transform: translate(-50%, -50%) scale(1.15);
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
    cursor: grabbing !important;
  }

  .coords-h { display: flex; justify-content: space-around; margin-left: 20px; color: #d4af37; font-size: 0.7rem; opacity: 0.6; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 20px; color: #d4af37; font-size: 0.7rem; opacity: 0.6; }
  .board-flex { display: flex; }

  .history-scroll { height: 100px; overflow-y: auto; color: #ccc; font-size: 0.8rem; }
  
  @media (min-width: 1200px) {
    .history-scroll { height: 400px; }
  }

  #game-status {
    background: rgba(0,0,0,0.8);
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 10px;
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
  }

  .gold-btn {
    width: 100%;
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 12px;
    font-family: 'Cinzel', serif;
    cursor: pointer;
    font-size: 0.8rem;
  }

  .mini-captured {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    min-height: 24px;
  }
</style>