---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Jugar VS IA">

  <div class="game-layout">

    <div class="game-status flex items-center gap-3">
      <p id="game-status" class="text-lg font-semibold bg-white shadow px-3 py-2 rounded-md">
        Turno de las blancas
      </p>

      <select id="ai-level" class="border rounded px-2 py-1 text-sm">
        <option value="1">Fácil</option>
        <option value="5" selected>Medio</option>
        <option value="10">Difícil</option>
        <option value="15">Muy difícil</option>
        <option value="20">Demonio</option>
      </select>
    </div>

    <div class="board-wrapper">
      <div class="coords-top">
        <span>A</span><span>B</span><span>C</span><span>D</span>
        <span>E</span><span>F</span><span>G</span><span>H</span>
      </div>

      <div class="coords-left">
        <span>8</span><span>7</span><span>6</span><span>5</span>
        <span>4</span><span>3</span><span>2</span><span>1</span>
      </div>

      <div id="board" class="board"></div>

      <div id="captured-area" class="mt-4 flex justify-between">
        <div id="captured-white" class="flex flex-wrap gap-1"></div>
        <div id="captured-black" class="flex flex-wrap gap-1"></div>
      </div>
    </div>

    <div class="move-history">
      <h2 class="text-xl font-bold mb-2">Historial</h2>
      <table class="text-sm border-collapse w-full">
        <thead>
          <tr><th>#</th><th>Blancas</th><th>Negras</th></tr>
        </thead>
        <tbody id="move-body"></tbody>
      </table>
    </div>

  </div>

  <script>
    import "../scripts/play-ia.ts";
  </script>

</BaseLayout>

<style>
  .game-layout {
    display: grid;
    grid-template-columns: 1fr auto 300px; /* Status | Board | History */
    gap: 2rem;
    padding: 2rem;
    align-items: start;
    justify-content: center;
  }

  .board-wrapper {
    position: relative;
    padding: 20px;
    background: var(--bg-panel);
    border: 2px solid var(--border-panel);
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.4);
  }

  /* Historial de movimientos lateral */
  .move-history {
    background: var(--bg-card);
    border: 1px solid var(--border-panel);
    border-radius: 12px;
    padding: 1.5rem;
    height: 600px;
    overflow-y: auto;
  }

  .move-history table {
    width: 100%;
    color: var(--text-main);
  }

  .move-history th {
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 8px;
    text-align: left;
  }

  .move-history td {
    padding: 8px 4px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  /* Nivel de IA Select */
  #ai-level {
    background: var(--bg-card);
    color: var(--text-main);
    border: 1px solid var(--color-gold);
    cursor: pointer;
  }

  /* Responsive para tablets/móvil */
  @media (max-width: 1100px) {
    .game-layout {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .move-history { width: 100%; max-width: 600px; height: 300px; }
  }
</style>