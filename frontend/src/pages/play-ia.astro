---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Desafío IA">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel players">
        <div class="player-box ai-card">
          <div class="player-header"><span>🤖 EINSTEIN (IA)</span></div>
          <select id="ai-level" class="gold-select">
            <option value="1">NIVEL: APRENDIZ</option>
            <option value="5" selected>NIVEL: MAESTRO</option>
            <option value="15">NIVEL: DEMONIO</option>
          </select>
          <div id="captured-white" class="mini-captured"></div>
        </div>
        
        <div class="status-center">
          <div id="game-status">TU TURNO</div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel history-area">
        <div class="player-box user-card">
          <div class="player-header"><span>♔ TÚ (BLANCAS)</span></div>
          <div id="captured-black" class="mini-captured"></div>
        </div>

        <div class="history-card">
          <div class="history-header">HISTORIAL</div>
          <div class="history-scroll">
            <table>
              <tbody id="move-body"></tbody>
            </table>
          </div>
        </div>
        
        <button id="resetBtn" class="gold-btn">REINICIAR PARTIDA</button>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/play-ia.ts";
  </script>
</BaseLayout>

<style is:global>
  /* Fix para el cursor de arrastre */
  body.is-dragging, body.is-dragging * {
    cursor: grabbing !important;
  }

  .main-screen {
    min-height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
    align-items: flex-start; 
    padding: 15px 10px;
    overflow-x: hidden;
  }

  .game-wrapper {
    display: flex;
    flex-direction: column;
    gap: 15px;
    width: 100%;
    align-items: center;
  }

  @media (min-width: 1200px) {
    .game-wrapper {
      display: grid;
      grid-template-columns: 240px 680px 240px; 
      gap: 40px;
      align-items: start;
      max-width: 1250px;
    }
    .main-screen { align-items: center; padding-top: 0; }
  }

  .side-panel { display: flex; flex-direction: column; gap: 15px; width: 100%; max-width: 500px; }

  .player-box, .history-card {
    background: rgba(0, 0, 0, 0.75);
    border: 1px solid rgba(212, 175, 55, 0.4);
    border-radius: 4px;
    padding: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .players {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .status-center { grid-column: span 2; }

  @media (min-width: 1200px) {
    .players { display: flex; flex-direction: column; grid-template-columns: none; }
    .status-center { grid-column: auto; }
  }

  .player-header, .history-header {
    font-family: 'Cinzel', serif;
    color: #d4af37;
    font-size: 0.8rem;
    letter-spacing: 1px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    padding-bottom: 6px;
    margin-bottom: 8px;
    text-align: center;
  }

  .board-frame {
    background: #1a2a3a; 
    padding: 10px;
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.2);
    box-shadow: 0 0 40px rgba(0,0,0,0.8);
    margin: 0 auto;
  }

  .compact-board {
    width: 86vw; 
    height: 86vw;
    max-width: 600px;
    max-height: 600px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    position: relative;
  }

  .square.light { background: #dee3e6; }
  .square.dark { background: #6085a1; }
  .square.selected { background: rgba(0, 191, 255, 0.4) !important; }
  .square.legal-move { box-shadow: inset 0 0 0 5px rgba(0, 191, 255, 0.5); cursor: pointer; }

  @media (min-width: 768px) {
    .board-frame { padding: 20px; }
    .compact-board { width: 550px; height: 550px; }
  }

  @media (min-width: 1200px) {
    .compact-board { width: 600px; height: 600px; }
  }

  .square { width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; }
  
  .piece { 
    width: 90%; 
    height: 90%; 
    cursor: grab; 
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.6)); 
    transition: opacity 0.2s ease;
    touch-action: none;
    z-index: 5;
  }

  .piece.dragging-active {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 65px;
    height: 65px;
    transform: translate(-50%, -50%) scale(1.15);
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
  }

  .coords-h { display: flex; justify-content: space-around; margin-left: 20px; color: #d4af37; font-size: 0.7rem; opacity: 0.6; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 20px; color: #d4af37; font-size: 0.7rem; opacity: 0.6; }
  .board-flex { display: flex; }

  .gold-select {
    width: 100%;
    background: #111;
    color: #d4af37;
    border: 1px solid rgba(212, 175, 55, 0.5);
    padding: 6px;
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    outline: none;
    cursor: pointer;
  }

  #game-status {
    background: rgba(0,0,0,0.8);
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 8px;
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .history-scroll { height: 100px; overflow-y: auto; color: #ccc; font-size: 0.8rem; }
  
  @media (min-width: 1200px) {
    .history-scroll { height: 300px; }
  }

  .gold-btn {
    width: 100%;
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 12px;
    font-family: 'Cinzel', serif;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: bold;
    transition: 0.3s;
  }
  .gold-btn:hover { background: #d4af37; color: black; }
  .mini-captured { display: flex; flex-wrap: wrap; gap: 2px; min-height: 28px; margin-top: 5px; }
</style>