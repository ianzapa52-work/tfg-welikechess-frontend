---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Desafío IA">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel top-panel">
        <div class="player-box ai-card">
          <div class="player-header"><span>🤖 EINSTEIN (IA)</span></div>
          <div class="controls-row">
            <select id="ai-level" class="gold-select">
              <option value="1">NIVEL: APRENDIZ</option>
              <option value="5" selected>NIVEL: MAESTRO</option>
              <option value="15">NIVEL: DEMONIO</option>
            </select>
            <div id="game-status" class="mobile-status">TU TURNO</div>
          </div>
          <div id="captured-white" class="mini-captured"></div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel bottom-panel">
        <div class="user-row">
          <div class="player-box user-card flex-1">
            <div class="player-header"><span>♔ TÚ (BLANCAS)</span></div>
            <div id="captured-black" class="mini-captured"></div>
          </div>
          
          <button id="resetBtn" class="gold-btn mobile-reset">REINICIAR</button>
        </div>

        <div class="history-card">
          <div class="history-header">HISTORIAL</div>
          <div class="history-scroll">
            <table class="w-full">
              <tbody id="move-body"></tbody>
            </table>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/play-ia.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start; 
    padding: 15px 10px;
  }

  .game-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 600px;
    gap: 15px;
  }

  @media (min-width: 1200px) {
    .game-wrapper {
      display: grid;
      grid-template-columns: 240px 650px 240px; 
      max-width: 1250px;
      gap: 30px;
      align-items: start;
    }
  }

  .side-panel { display: flex; flex-direction: column; gap: 12px; }

  .player-box, .history-card {
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 12px;
    border-radius: 4px;
  }

  /* COORDENADAS Y TABLERO SINCRONIZADOS */
  .board-frame {
    background: #2c2c2c;
    padding: 10px;
    border-radius: 4px;
    border: 4px solid #3d3d3d;
    margin: 0 auto;
    width: fit-content;
  }

  .board-flex { display: flex; }

  .compact-board {
    width: 82vw; 
    height: 82vw;
    max-width: 520px;
    max-height: 520px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    aspect-ratio: 1/1;
  }

  .coords-h { 
    display: grid; 
    grid-template-columns: repeat(8, 1fr); 
    margin-left: 22px; 
    margin-bottom: 4px; 
    color: #d4af37; 
    font-size: 0.7rem;
    text-align: center;
  }

  .coords-v { 
    display: grid; 
    grid-template-rows: repeat(8, 1fr); 
    width: 22px; 
    color: #d4af37; 
    font-size: 0.7rem; 
    text-align: center;
    align-items: center;
  }

  @media (min-width: 768px) {
    .compact-board { width: 550px; height: 550px; }
  }

  .history-scroll { 
    height: 140px; 
    overflow-y: auto; 
    font-size: 0.85rem; 
  }

  @media (min-width: 1200px) {
    .history-scroll { height: 350px; }
  }

  .gold-btn {
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 10px;
    cursor: pointer;
    font-family: 'Cinzel', serif;
    font-weight: bold;
  }

  .controls-row { display: flex; gap: 8px; align-items: center; margin-top: 8px; }
  .user-row { display: flex; gap: 10px; }
  .mobile-status { font-size: 0.7rem; color: #d4af37; font-weight: bold; }
</style>