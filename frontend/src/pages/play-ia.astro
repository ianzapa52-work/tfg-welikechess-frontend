---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Desafío IA">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel top-panel">
        <div class="player-box ai-card">
          <div class="player-header"><span>🤖 EINSTEIN (IA)</span></div>
          <div class="controls-row">
            <select id="ai-level" class="gold-select">
              <option value="1">NIVEL: APRENDIZ</option>
              <option value="5" selected>NIVEL: MAESTRO</option>
              <option value="15">NIVEL: DEMONIO</option>
            </select>
            <div id="game-status" class="mobile-status">TU TURNO</div>
          </div>
          <div id="captured-white" class="mini-captured"></div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel bottom-panel">
        <div class="user-row">
          <div class="player-box user-card flex-1">
            <div class="player-header"><span>♔ TÚ (BLANCAS)</span></div>
            <div id="captured-black" class="mini-captured"></div>
          </div>
          
          <button id="resetBtn" class="gold-btn mobile-reset">REINICIAR</button>
        </div>

        <div class="history-card">
          <div class="history-header">HISTORIAL</div>
          <div class="history-scroll">
            <table class="w-full">
              <tbody id="move-body"></tbody>
            </table>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/play-ia.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start; 
    padding: 20px 10px; /* Padding reducido para ganar espacio */
  }

  /* LAYOUT RESPONSIVO: De 1 columna a 3 columnas */
  .game-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 600px; /* En móvil no queremos que exceda el tablero */
    gap: 15px;
  }

  @media (min-width: 1200px) {
    .game-wrapper {
      display: grid;
      grid-template-columns: 240px 680px 240px; 
      max-width: 1200px;
      gap: 40px;
      align-items: start;
    }
  }

  .side-panel {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  /* Ajustes para compactar la UI en móviles */
  .controls-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 5px;
  }

  .user-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }

  .player-box, .history-card, .status-box {
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 12px;
    border-radius: 4px;
  }

  /* EL TABLERO RESPONSIVO */
  .board-frame {
    background: #2c2c2c;
    padding: 10px; /* Padding reducido en móvil */
    border-radius: 4px;
    border: 4px solid #3d3d3d;
    margin: 0 auto;
    width: fit-content;
  }

  /* Tamaño dinámico basado en el ancho de pantalla */
  .compact-board {
    width: 85vw; /* Casi todo el ancho del móvil */
    height: 85vw;
    max-width: 600px;
    max-height: 600px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
  }

  @media (min-width: 768px) {
    .board-frame { padding: 20px; }
    .compact-board { width: 600px; height: 600px; }
  }

  /* Las piezas deben escalar con el tablero */
  .square { 
    width: 100%; 
    height: 100%; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
  }
  
  .piece { 
    width: 90%; 
    height: 90%; 
    cursor: grab; 
    filter: drop-shadow(2px 2px 2px rgba(0,0,0,0.3)); 
  }

  /* Coordenadas */
  .coords-h { display: flex; justify-content: space-around; padding-left: 20px; margin-bottom: 4px; color: #d4af37; font-size: 0.75rem; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 20px; color: #d4af37; font-size: 0.75rem; }
  
  /* Ajustes de Historial para móvil */
  .history-scroll { 
    height: 120px; /* Más bajo en móvil para no empujar todo abajo */
    overflow-y: auto; 
    font-size: 0.8rem; 
  }

  @media (min-width: 1200px) {
    .history-scroll { height: 300px; }
    .mobile-reset { width: 100%; }
  }

  .gold-btn {
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 10px;
    cursor: pointer;
    font-family: 'Cinzel';
    font-weight: bold;
  }

  .mobile-status {
    flex: 1;
    white-space: nowrap;
    font-size: 0.75rem !important;
  }
</style>