---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Puzzles Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel top-panel">
        <div class="flex gap-3">
          <div class="player-box ai-card flex-1">
            <div class="player-header"><span>🎯 OBJETIVO</span></div>
            <div id="puzzleObjective" class="status-text !text-yellow-500 font-bold">Cargando...</div>
          </div>
          
          <div class="status-box flex-1 flex items-center justify-center">
            <div id="puzzle-feedback" class="status-text font-black tracking-widest">TU TURNO</div>
          </div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel bottom-panel">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="history-card flex-1">
            <div class="history-header">PROGRESO</div>
            <div class="stats-content flex items-center justify-between px-2">
              <p class="text-[10px] uppercase tracking-widest text-zinc-500">Resueltos</p>
              <span id="solved-count" class="gold-text">0</span>
            </div>
            <div id="already-done-badge" class="hidden-badge mt-2">✨ COMPLETADO</div>
          </div>

          <button id="nextPuzzle" class="gold-btn flex-1 !py-4">SIGUIENTE PUZZLE</button>
        </div>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/puzzles.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen { min-height: 100vh; display: flex; justify-content: center; align-items: flex-start; padding: 15px 10px; }

  .game-wrapper { display: flex; flex-direction: column; gap: 15px; width: 100%; max-width: 600px; }

  @media (min-width: 1200px) {
    .game-wrapper { display: grid; grid-template-columns: 240px 600px 240px; gap: 40px; align-items: center; max-width: 1200px; }
  }

  .board-frame { 
    background: #1a1a1a; 
    padding: 10px; 
    border-radius: 6px; 
    border: 3px solid #333; 
    margin: 0 auto;
  }

  .compact-board { 
    width: 82vw; 
    height: 82vw; 
    max-width: 500px; 
    max-height: 500px; 
    display: grid; 
    grid-template-columns: repeat(8, 1fr); 
    grid-template-rows: repeat(8, 1fr); /* CORRECCIÓN FILA PEQUEÑA */
    aspect-ratio: 1/1;
  }

  .board-flex { display: flex; }

  .coords-h { display: grid; grid-template-columns: repeat(8, 1fr); margin-left: 20px; text-align: center; color: #d4af37; font-size: 0.7rem; margin-bottom: 4px; }
  .coords-v { display: grid; grid-template-rows: repeat(8, 1fr); width: 20px; text-align: center; align-items: center; color: #d4af37; font-size: 0.7rem; }

  .player-box, .history-card, .status-box { background: rgba(10, 10, 10, 0.9); border: 1px solid rgba(212, 175, 55, 0.3); padding: 12px; border-radius: 8px; }
  .gold-text { color: #d4af37; font-weight: 900; font-size: 1.2rem; }
  .gold-btn { background: #d4af37; border: none; color: black; font-family: 'Cinzel', serif; font-weight: bold; border-radius: 6px; cursor: pointer; }
</style>