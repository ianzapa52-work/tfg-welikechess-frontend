---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Puzzles Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel">
        <div class="player-box ai-card">
          <div class="player-header"><span>🎯 OBJETIVO</span></div>
          <div id="puzzleObjective" class="status-text">Cargando...</div>
        </div>
        
        <div class="status-box">
          <div id="puzzle-feedback" class="status-text font-bold">TU TURNO</div>
        </div>

        <button id="nextPuzzle" class="gold-btn">SIGUIENTE PUZZLE</button>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel">
        <div class="history-card">
          <div class="history-header">PROGRESO</div>
          <div class="stats-content">
            <p class="mb-2">Resueltos: <span id="solved-count" class="gold-text">0</span></p>
            <div id="already-done-badge" class="hidden-badge">
              ✨ YA COMPLETADO
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/puzzles.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen { min-height: 100vh; display: flex; justify-content: center; align-items: flex-start; padding-top: 50px; }
  .game-wrapper { display: grid; grid-template-columns: 240px 680px 240px; gap: 40px; align-items: start; }
  .side-panel { display: flex; flex-direction: column; gap: 20px; }
  
  .player-box, .history-card, .status-box {
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 15px; border-radius: 4px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .status-text { color: #eee; text-align: center; font-family: 'Cinzel', serif; font-size: 0.85rem; }
  .gold-text { color: #d4af37; font-weight: bold; font-size: 1.2rem; }
  
  .hidden-badge { 
    display: none; 
    background: rgba(212, 175, 55, 0.1); 
    color: #d4af37; 
    padding: 8px; 
    border-radius: 4px; 
    font-size: 0.7rem; 
    text-align: center;
    border: 1px dashed #d4af37;
  }

  .board-frame { background: #2c2c2c; padding: 20px; border-radius: 4px; border: 4px solid #3d3d3d; }
  .compact-board { width: 600px; height: 600px; display: grid; grid-template-columns: repeat(8, 1fr); }
  
  .square { width: 75px; height: 75px; display: flex; justify-content: center; align-items: center; position: relative; }
  .square.light { background: #ebecd0; }
  .square.dark { background: #779556; }
  
  /* Indicadores visuales */
  .square.selected { background: rgba(212, 175, 55, 0.5) !important; }
  .square.error-flash { background: rgba(248, 113, 113, 0.6) !important; transition: background 0.2s; }

  .coords-h, .coords-v { color: #d4af37; font-weight: bold; font-size: 0.9rem; font-family: 'Cinzel'; }
  .coords-h { display: flex; justify-content: space-around; padding-left: 25px; margin-bottom: 8px; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 25px; }
  .board-flex { display: flex; }

  .gold-btn {
    background: transparent; border: 1px solid #d4af37; color: #d4af37;
    padding: 12px; cursor: pointer; font-family: 'Cinzel'; transition: 0.3s; font-weight: bold;
  }
  .gold-btn:hover { background: #d4af37; color: black; }
  
  .piece { 
    width: 70px; height: 70px; cursor: grab; z-index: 10;
    transition: transform 0.1s ease;
  }
  .piece:active { cursor: grabbing; transform: scale(1.1); }
  .piece.dragging { opacity: 0.4; }
</style>