---
import BaseLayout from "../layouts/BaseLayout.astro";
import AchievementToast from "../components/AchievementToast";
---

<BaseLayout title="WELIKECHESS - Puzzles Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel">
        <div class="ui-card objective-card">
          <div class="card-header">
            <span class="icon">🎯</span>
            <span class="title">OBJETIVO</span>
          </div>
          <div id="puzzleObjective" class="objective-text">Cargando...</div>
        </div>
        
        <div class="status-container">
          <div id="puzzle-feedback" class="status-badge">TU TURNO</div>
        </div>

        <button id="nextPuzzle" class="premium-btn">
          <span>SIGUIENTE PUZZLE</span>
          <div class="btn-glow"></div>
        </button>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel">
        <div class="ui-card progress-card">
          <div class="card-header">PROGRESO</div>
          <div class="stats-wrapper">
            <div class="stat-main">
              <span id="solved-count" class="stat-number">0</span>
              <p class="stat-label">Puzzles Resueltos</p>
            </div>
          </div>
        </div>
        <AchievementToast client:load />
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/puzzles.ts";
  </script>
</BaseLayout>

<style is:global>
  body.is-dragging, body.is-dragging * {
    cursor: grabbing !important;
  }

  .main-screen {
    min-height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
    align-items: center; 
    padding: 20px;
  }

  .game-wrapper {
    display: grid; 
    grid-template-columns: 260px 680px 260px; 
    gap: 30px; 
    align-items: center;
  }

  .board-frame {
    background: rgba(10, 31, 22, 0.8);
    padding: 15px;
    border-radius: 8px;
    position: relative;
  }

  .compact-board {
    width: 600px;
    height: 600px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    border: 4px solid #1a1a1a;
    user-select: none;
    position: relative;
  }

  .square { 
    width: 100%; height: 100%; 
    display: flex; justify-content: center; align-items: center; 
  }

  .square.light { background: #eeeed2; }
  .square.dark { background: #769656; }

  .piece { 
    width: 90%; 
    height: 90%; 
    cursor: grab;
    z-index: 5;
    user-select: none;
    touch-action: none;
    transition: opacity 0.2s ease; /* Suaviza el efecto fantasma */
  }

  .piece.dragging-active {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 65px;
    height: 65px;
    transform: translate(-50%, -50%) scale(1.1);
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));
    cursor: grabbing !important;
  }

  .square.legal-move { box-shadow: inset 0 0 0 5px #16de69; }
  .square.selected { background-color: rgba(246, 246, 130, 0.8) !important; }
  .square.success-flash { background: rgba(14, 221, 100, 0.8) !important; }
  .square.error-flash { background: rgba(236, 41, 20, 0.9) !important; }
  
  .side-panel { display: flex; flex-direction: column; gap: 20px; }
  .ui-card { background: linear-gradient(145deg, rgba(13, 43, 31, 0.9), rgba(7, 24, 17, 0.95)); border: 1px solid rgba(46, 204, 113, 0.3); border-radius: 12px; padding: 24px; }
  .card-header { display: flex; align-items: center; gap: 8px; font-family: 'Cinzel', serif; color: #2ecc71; font-size: 0.85rem; margin-bottom: 15px; }
  .objective-text { font-size: 1.1rem; color: #ffffff; }
  .status-badge { background: rgba(10, 31, 22, 0.8); border: 1px solid rgba(46, 204, 113, 0.5); color: #2ecc71; text-align: center; padding: 16px; border-radius: 8px; font-weight: 800; }
  .premium-btn { background: #1a1a1a; border: 1px solid #2ecc71; color: #2ecc71; padding: 16px; border-radius: 8px; font-weight: bold; cursor: pointer; position: relative; overflow: hidden; }
  .stat-number { display: block; font-size: 3.2rem; font-weight: 900; color: #f1c40f; text-align: center; }
  .stat-label { color: #ccc; font-size: 0.75rem; text-transform: uppercase; text-align: center; }
  .coords-h, .coords-v { color: #2ecc71; font-size: 0.75rem; font-weight: bold; opacity: 0.6; }
  .coords-h { display: flex; justify-content: space-around; padding-bottom: 5px; padding-left: 20px; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 20px; }
  .board-flex { display: flex; }
</style>