---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Registro">

  <!-- Contenedor centrado pero ligeramente más arriba -->
  <div class="h-[calc(100vh-4rem)] flex flex-col items-center justify-center translate-y-[-70px]">

    <!-- Rey más grande, sin zoom, con hover dorado -->
    <div class="flex justify-center mb-4">
      <img
        id="kingIcon"
        src="/pieces/w_king.svg"
        alt="Logo"
        class="w-16 opacity-90 cursor-pointer transition-all duration-300"
      />
    </div>

    <!-- Caja del registro con efecto dorado en hover -->
    <div
      id="registerCard"
      class="w-[380px] bg-white p-8 rounded-xl shadow-lg transform transition-all duration-300 hover:shadow-2xl"
    >
      <h1 class="text-3xl font-bold mb-6 text-center" style="font-family: 'Cinzel', serif;">
        Registro
      </h1>

      <form id="registerForm" class="flex flex-col gap-4">

        <div>
          <label class="block mb-1 font-medium">Nombre</label>
          <input
            id="name"
            type="text"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:outline-none"
            required
          />
          <p id="nameError" class="text-red-600 text-sm hidden">El nombre es obligatorio</p>
        </div>

        <div>
          <label class="block mb-1 font-medium">Email</label>
          <input
            id="email"
            type="email"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:outline-none"
            required
          />
          <p id="emailError" class="text-red-600 text-sm hidden">Email inválido</p>
        </div>

        <div>
          <label class="block mb-1 font-medium">Contraseña</label>
          <input
            id="password"
            type="password"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:outline-none"
            required
          />
          <p id="passwordError" class="text-red-600 text-sm hidden">La contraseña es obligatoria</p>
        </div>

        <button
          type="submit"
          class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 rounded-lg transition cursor-pointer"
        >
          Crear cuenta
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-4">
        ¿Ya tienes cuenta?
        <a href="/login" class="text-green-600 hover:underline">Inicia sesión</a>
      </p>
    </div>
  </div>

  <script type="module" src="/src/scripts/register.js"></script>
</BaseLayout>
