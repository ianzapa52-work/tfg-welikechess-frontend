---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Registro">

  <div class="min-h-[calc(100vh-4rem)] flex flex-col items-center justify-center p-4 py-8">

    <div class="flex justify-center mb-6">
      <img
        id="kingIcon"
        src="/pieces/w_king.svg"
        alt="Logo"
        class="w-12 md:w-16 opacity-90 cursor-pointer transition-all duration-300 hover:scale-110"
      />
    </div>

    <div
      id="registerCard"
      class="register-card w-full max-w-[400px] p-6 md:p-8 rounded-2xl shadow-2xl transition-all duration-300
             bg-white text-black
             dark:bg-[rgba(15,15,15,0.95)]
             dark:border dark:border-[#d4af37]/50
             dark:text-white"
    >

      <h1 class="text-2xl md:text-3xl font-bold mb-6 text-center dark:text-white tracking-tight" style="font-family: 'Cinzel', serif;">
        Registro
      </h1>

      <form id="registerForm" class="flex flex-col gap-5">

        <div class="space-y-1.5">
          <label class="block text-xs md:text-sm font-black uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Nombre de Usuario</label>
          <input
            id="registerUsername"
            type="text"
            placeholder="Ej: Kasparov99"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-black
                   focus:ring-2 focus:ring-[#d4af37] focus:outline-none transition-all
                   dark:bg-white/5
                   dark:border-white/10
                   dark:text-white dark:placeholder:text-zinc-600"
            required
          />
        </div>

        <div class="space-y-1.5">
          <label class="block text-xs md:text-sm font-black uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Correo Electrónico</label>
          <input
            id="registerEmail"
            type="email"
            placeholder="tu@email.com"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-black
                   focus:ring-2 focus:ring-[#d4af37] focus:outline-none transition-all
                   dark:bg-white/5
                   dark:border-white/10
                   dark:text-white dark:placeholder:text-zinc-600"
            required
          />
        </div>

        <div class="space-y-1.5">
          <label class="block text-xs md:text-sm font-black uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Contraseña</label>
          <input
            id="registerPassword"
            type="password"
            placeholder="••••••••"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-black
                   focus:ring-2 focus:ring-[#d4af37] focus:outline-none transition-all
                   dark:bg-white/5
                   dark:border-white/10
                   dark:text-white dark:placeholder:text-zinc-600"
            required
          />
        </div>

        <button
          type="submit"
          class="w-full py-4 mt-2 rounded-xl font-black uppercase tracking-[0.2em] text-xs transition-all cursor-pointer
                 bg-zinc-900 text-white hover:bg-black
                 dark:bg-[#d4af37] dark:hover:bg-[#f5d67b] dark:text-black
                 shadow-[0_10px_20px_rgba(0,0,0,0.2)] active:scale-95"
        >
          Crear cuenta
        </button>
      </form>

      <p class="text-center text-xs md:text-sm text-gray-500 mt-6 dark:text-gray-400">
        ¿Ya tienes cuenta?
        <a href="/login" class="font-bold text-zinc-900 hover:underline dark:text-[#d4af37]">Inicia sesión</a>
      </p>
    </div>
  </div>

  <script>
    import "../scripts/register.js";
  </script>

</BaseLayout>

<style>
  /* Animación de entrada suave */
  .register-card {
    animation: cardEnter 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes cardEnter {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mejora visual para los inputs en modo oscuro al hacer autofill */
  input:-webkit-autofill,
  input:-webkit-autofill:hover, 
  input:-webkit-autofill:focus {
    -webkit-text-fill-color: white;
    -webkit-box-shadow: 0 0 0px 1000px #1a1a1a inset;
    transition: background-color 5000s ease-in-out 0s;
  }
</style>