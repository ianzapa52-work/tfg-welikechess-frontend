---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Configuración">

  <div class="settings-wrapper pt-20 pb-16">

    <h1
      class="text-6xl font-black mb-10 text-center
             bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
             bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      CONFIGURACIÓN
    </h1>

    <section class="settings-panel">

      <div class="settings-grid">

        <div class="space-y-8">

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-user-circle"></i>
              <h2>CUENTA</h2>
            </div>

            <div class="setting-item">
              <label>Nombre de usuario</label>
              <input type="text" placeholder="Tu nombre..." class="custom-input" />
            </div>

            <div class="setting-item">
              <label>Correo electrónico</label>
              <input type="email" placeholder="ejemplo@correo.com" class="custom-input" />
            </div>

            <div class="setting-item">
              <label>Seguridad</label>
              <button class="action-btn-outline">Cambiar contraseña</button>
            </div>
          </div>

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-volume-up"></i>
              <h2>AUDIO</h2>
            </div>

            <div class="setting-item">
              <div class="flex justify-between">
                <label>Volumen general</label>
                <span class="value-badge">70%</span>
              </div>
              <input type="range" min="0" max="100" value="70" class="slider-range" />
            </div>

            <div class="setting-item">
              <div class="flex justify-between">
                <label>Efectos de sonido</label>
                <span class="value-badge">50%</span>
              </div>
              <input type="range" min="0" max="100" value="50" class="slider-range" />
            </div>
          </div>
        </div>

        <div class="space-y-8">

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-shield-alt"></i>
              <h2>PRIVACIDAD</h2>
            </div>

            <div class="setting-item horizontal">
              <label>Estado en línea</label>
              <label class="switch">
                <input type="checkbox" checked />
                <span class="slider"></span>
              </label>
            </div>

            <div class="setting-item horizontal">
              <label>Solicitudes de amistad</label>
              <label class="switch">
                <input type="checkbox" checked />
                <span class="slider"></span>
              </label>
            </div>
          </div>

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-paint-brush"></i>
              <h2>INTERFAZ</h2>
            </div>

            <div class="setting-item">
              <label>Tema visual</label>
              <select class="custom-select">
                <option value="default">Madera Clásica</option>
                <option value="dark">Noche de Ébano</option>
                <option value="gold">Oro Real</option>
              </select>
            </div>

            <div class="setting-item horizontal">
              <label>Animaciones fluidas</label>
              <label class="switch">
                <input type="checkbox" checked />
                <span class="slider"></span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <div class="pt-8 flex justify-center">
        <button class="save-master-btn">
          <span>GUARDAR CAMBIOS</span>
        </button>
      </div>

    </section>
  </div>

  <script type="module" src="/src/scripts/settings.js"></script>

</BaseLayout>

<style>
  .settings-wrapper { 
    max-width: 1000px; 
    margin: 0 auto; 
  }

  .settings-panel {
    background: rgba(15, 15, 15, 0.95);
    border: 2px solid rgba(212, 175, 55, 0.4);
    border-radius: 40px;
    padding: 3.5rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 40px 100px rgba(0,0,0,0.8), inset 0 0 40px rgba(212,175,55,0.05);
  }

  .settings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .settings-section {
    background: rgba(255, 255, 255, 0.03);
    padding: 2rem;
    border-radius: 25px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 2rem;
    color: #d4af37;
  }

  .settings-section h2 {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 1px;
  }

  .setting-item {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 1.5rem;
  }

  .setting-item.horizontal {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .setting-item label {
    font-size: 0.95rem;
    color: #aaa;
    font-weight: 500;
  }

  /* INPUTS */
  .custom-input, .custom-select {
    width: 100%;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.9rem 1.2rem;
    border-radius: 12px;
    color: white;
  }

  .custom-input:focus {
    border-color: #d4af37;
    outline: none;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.2);
  }

  /* BUTTONS */
  .action-btn-outline {
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 0.7rem;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .action-btn-outline:hover {
    background: #d4af37;
    color: black;
  }

  .save-master-btn {
    background: linear-gradient(to bottom, #d4af37, #996515);
    color: black;
    padding: 1.2rem 4rem;
    border-radius: 15px;
    font-weight: 900;
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    transition: transform 0.3s;
  }

  .save-master-btn:hover {
    transform: scale(1.05);
  }

  /* SWITCHES */
  .switch {
    position: relative;
    display: inline-block;
    width: 46px;
    height: 24px;
  }

  .switch input { opacity: 0; width: 0; height: 0; }

  .slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #333;
    transition: .4s;
    border-radius: 34px;
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 18px; width: 18px;
    left: 3px; bottom: 3px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
  }

  input:checked + .slider { background-color: #d4af37; }
  input:checked + .slider:before { transform: translateX(22px); }

  .value-badge {
    font-size: 0.8rem;
    color: #d4af37;
    background: rgba(212, 175, 55, 0.1);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .slider-range {
    width: 100%;
    accent-color: #d4af37;
  }
</style>