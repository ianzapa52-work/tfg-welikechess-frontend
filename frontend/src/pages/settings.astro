---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Configuración">
  <div class="settings-wrapper pt-20 pb-16">
    <h1
      class="text-6xl font-black mb-10 text-center
             bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
             bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      CONFIGURACIÓN
    </h1>

    <section class="settings-panel">
      <div class="settings-grid">
        <div class="space-y-8">
          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-user-circle"></i>
              <h2>CUENTA</h2>
            </div>
            <div class="setting-item">
              <label for="username">Nombre de usuario</label>
              <input id="username" type="text" placeholder="Tu nombre..." class="custom-input" />
            </div>
            <div class="setting-item">
              <label for="email">Correo electrónico</label>
              <input id="email" type="email" placeholder="ejemplo@correo.com" class="custom-input" />
            </div>
          </div>

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-volume-up"></i>
              <h2>AUDIO</h2>
            </div>
            <div class="setting-item">
              <div class="flex justify-between">
                <label>Volumen general</label>
                <span class="value-badge" id="val-general">70%</span>
              </div>
              <input id="volume-general" type="range" min="0" max="100" value="70" class="slider-range" />
            </div>
          </div>
        </div>

        <div class="space-y-8">
          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-shield-alt"></i>
              <h2>PRIVACIDAD</h2>
            </div>
            <div class="setting-item horizontal">
              <label for="online-status">Estado en línea</label>
              <label class="switch">
                <input id="online-status" type="checkbox" checked />
                <span class="slider"></span>
              </label>
            </div>
          </div>

          <div class="settings-section">
            <div class="section-header">
              <i class="fas fa-paint-brush"></i>
              <h2>INTERFAZ</h2>
            </div>
            <div class="setting-item">
              <label for="theme-select">Tema visual</label>
              <select id="theme-select" class="custom-select">
                <option value="dark">Oscuro</option>
                <option value="light">Claro</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="pt-8 flex justify-center">
        <button id="save-settings-btn" class="save-master-btn">
          <span>GUARDAR CAMBIOS</span>
        </button>
      </div>
    </section>
  </div>

  <script>
    import "../scripts/settings.js";
  </script>
  
</BaseLayout>

<style>
  .settings-wrapper { max-width: 1000px; margin: 0 auto; }
  .settings-panel {
    background: var(--bg-panel);
    border: 2px solid rgba(212, 175, 55, 0.4);
    border-radius: 40px;
    padding: 3.5rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    transition: background 0.3s ease;
  }
  .settings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 3rem; }
  .settings-section { 
    background: rgba(255, 255, 255, 0.05); 
    padding: 2rem; 
    border-radius: 25px; 
    border: 1px solid var(--border-panel); 
  }
  .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 2rem; color: var(--color-gold); }
  .setting-item { display: flex; flex-direction: column; gap: 10px; margin-bottom: 1.5rem; }
  .setting-item.horizontal { flex-direction: row; justify-content: space-between; align-items: center; }
  .custom-input, .custom-select { 
    width: 100%; 
    background: rgba(0, 0, 0, 0.3); 
    border: 1px solid rgba(255, 255, 255, 0.1); 
    padding: 0.9rem 1.2rem; 
    border-radius: 12px; 
    color: var(--text-main); 
  }
  .save-master-btn { 
    background: linear-gradient(to bottom, var(--color-gold), var(--color-gold-dark)); 
    color: black; 
    padding: 1.2rem 4rem; 
    border-radius: 15px; 
    font-weight: 900; 
    cursor: pointer; 
    transition: transform 0.2s; 
  }
  .save-master-btn:hover { transform: scale(1.05); }
  .switch { position: relative; width: 46px; height: 24px; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #333; transition: .4s; border-radius: 34px; }
  .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
  input:checked + .slider { background-color: var(--color-gold); }
  input:checked + .slider:before { transform: translateX(22px); }
  .value-badge { color: var(--color-gold); background: rgba(212, 175, 55, 0.1); padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; }
  .slider-range { width: 100%; accent-color: var(--color-gold); }
</style>