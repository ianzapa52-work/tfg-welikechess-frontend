---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Perfil" bodyClass="perfil-page">

  <div class="min-h-screen pt-6 pb-24 px-4 sm:px-12 max-w-7xl mx-auto flex flex-col">
    
    <div id="profile-user" class="hidden flex flex-col gap-8 md:gap-20">
      
      <header class="bg-black/30 backdrop-blur-xl border border-white/10 rounded-[2rem] md:rounded-[3rem] p-6 md:p-16 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-yellow-600/10 blur-[80px] md:blur-[150px] rounded-full"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-16">
          <div class="relative group">
            <div class="absolute -inset-2 md:-inset-4 bg-gradient-to-tr from-yellow-600 to-amber-400 rounded-[2rem] md:rounded-[3rem] blur opacity-20 group-hover:opacity-40 transition duration-700"></div>
            
            <img id="current-avatar" src="/avatars/w_king_avatar.png" class="relative w-40 h-40 md:w-64 md:h-64 rounded-[2rem] md:rounded-[2.5rem] border-2 border-yellow-500/20 object-cover shadow-2xl z-10"/>
            
            <button id="openAvatarMenu" class="absolute -bottom-3 left-1/2 -translate-x-1/2 px-6 py-2 md:px-8 md:py-3 bg-yellow-500 hover:bg-yellow-400 text-black font-black rounded-xl md:rounded-2xl text-[10px] md:text-xs uppercase shadow-2xl transition-transform hover:scale-110 whitespace-nowrap cursor-pointer z-30">
              Cambiar Foto
            </button>

            <div id="avatarMenu" class="hidden absolute top-full left-1/2 -translate-x-1/2 mt-4 z-50 bg-[#1a1a1a] border-2 border-yellow-500 p-4 rounded-[1.5rem] shadow-2xl w-[260px]">
            </div>
          </div>

          <div class="flex-1 space-y-6 md:space-y-10 text-center md:text-left w-full">
            <div>
              <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-6 mb-2 md:mb-4">
                <h2 class="text-4xl sm:text-5xl md:text-8xl font-black text-white tracking-tighter break-words" id="profile-username">---</h2>
                <span class="inline-block self-center md:self-auto bg-yellow-500/10 border border-yellow-500/20 px-4 py-1 rounded-full text-yellow-500 text-[10px] font-black uppercase tracking-widest">Premium</span>
              </div>
              <p class="text-zinc-400 text-lg md:text-2xl font-medium italic truncate" id="profile-email">---</p>
            </div>
            
            <div class="flex flex-col sm:flex-row justify-center md:justify-start gap-6 md:gap-12">
              <div class="flex flex-col gap-2 md:gap-3">
                <span class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Nivel Actual</span>
                <div class="bg-zinc-900/80 border border-white/5 px-6 py-4 md:px-10 md:py-6 rounded-[1.5rem] md:rounded-[2rem] flex items-center justify-center md:justify-start gap-4 md:gap-6">
                    <span class="text-4xl md:text-6xl font-black text-white" id="stat-rating">0</span>
                    <span class="text-yellow-600 font-black text-base md:text-xl uppercase">ELO</span>
                </div>
              </div>
              <div class="flex items-center justify-center md:items-end md:pb-2">
                <button id="logoutBtn" class="w-full sm:w-auto px-8 py-4 bg-red-950/20 hover:bg-red-900/40 border border-red-900/30 text-red-400 rounded-2xl transition-all text-[10px] font-black uppercase tracking-widest cursor-pointer">Cerrar Sesión</button>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-16">
        
        <div class="lg:col-span-8 bg-zinc-900/20 border border-white/5 p-8 md:p-16 rounded-[2.5rem] md:rounded-[4rem] shadow-xl">
          <h3 class="text-white font-black uppercase text-xs tracking-[0.3em] mb-10 md:mb-20 flex items-center gap-4 md:gap-6">
            <span class="w-8 md:w-12 h-[2px] bg-yellow-600"></span> ESTADÍSTICAS
          </h3>
          
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 md:gap-12 text-center md:text-left">
            <div class="space-y-2 md:space-y-4">
                <p class="text-zinc-500 text-[10px] font-black uppercase tracking-widest">Jugadas</p>
                <p id="stat-games" class="text-4xl md:text-7xl font-black text-white leading-none">0</p>
            </div>
            <div class="space-y-2 md:space-y-4">
                <p class="text-green-500/60 text-[10px] font-black uppercase tracking-widest">Win</p>
                <p id="stat-wins" class="text-4xl md:text-7xl font-black text-green-400 leading-none">0</p>
            </div>
            <div class="space-y-2 md:space-y-4">
                <p class="text-red-500/60 text-[10px] font-black uppercase tracking-widest">Loss</p>
                <p id="stat-losses" class="text-4xl md:text-7xl font-black text-red-400 leading-none">0</p>
            </div>
            <div class="space-y-2 md:space-y-4">
                <p class="text-blue-500/60 text-[10px] font-black uppercase tracking-widest">Draw</p>
                <p id="stat-draws" class="text-4xl md:text-7xl font-black text-blue-400 leading-none">0</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4 bg-zinc-900/20 border border-white/5 p-8 md:p-16 rounded-[2.5rem] md:rounded-[4rem] flex flex-col justify-between shadow-xl">
          <div class="space-y-4 md:space-y-8">
            <h3 class="text-white font-black uppercase text-xs tracking-[0.3em]">Puzzles</h3>
            <p id="stat-puzzles-solved" class="text-6xl md:text-8xl font-black text-white leading-none">0</p>
            <p id="stat-puzzles-failed" class="text-zinc-500 text-[10px] font-black uppercase">Fallos: 0</p>
          </div>
          <div class="space-y-6 pt-8 md:pt-12">
            <div class="w-full bg-black/40 rounded-full h-3 md:h-4 p-1">
                <div id="puzzle-progress" class="bg-gradient-to-r from-yellow-600 to-yellow-400 h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    import "../scripts/profile.ts";
  </script>

</BaseLayout>

<style>
  #profile-user { animation: fadeIn 0.8s ease-out forwards; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  #avatarMenu {
    display: none;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    max-height: 300px;
    overflow-y: auto;
  }
  
  #avatarMenu:not(.hidden) {
    display: grid;
  }

  /* Ajuste de avatares para que quepan bien en el menú móvil */
  :global(#avatarMenu img) {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s ease;
  }

  :global(#avatarMenu img:hover) {
    transform: scale(1.05);
    border-color: #d4af37;
  }

  /* Scrollbar fina para el menú de avatares */
  #avatarMenu::-webkit-scrollbar { width: 4px; }
  #avatarMenu::-webkit-scrollbar-thumb { background: #d4af37; border-radius: 10px; }
</style>