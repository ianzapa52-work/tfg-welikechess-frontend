---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Perfil">

  <div class="mt-20 px-6">

    <div id="profile-user" class="hidden grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- COLUMNA IZQUIERDA -->
      <div class="col-span-1 flex flex-col gap-6">

        <!-- Banner -->
        <div class="bg-linear-to-r from-yellow-500 to-amber-600 text-white p-6 rounded-xl shadow-md text-center">
          <h2 class="text-3xl font-bold" id="profile-username"></h2>
          <p class="opacity-90" id="profile-email"></p>
        </div>

        <!-- Rating -->
        <div class="bg-white dark:bg-[rgba(20,20,20,0.85)] dark:text-white p-5 rounded-xl shadow">
          <h3 class="font-semibold text-xl mb-2">Rating</h3>
          <p id="stat-rating" class="text-2xl font-bold"></p>
        </div>

        <!-- Selector de avatar -->
        <div class="bg-white dark:bg-[rgba(20,20,20,0.85)] dark:text-white p-5 rounded-xl shadow relative">
          <h3 class="font-semibold text-xl mb-3">Avatar</h3>

          <!-- Avatar actual + botón -->
          <div class="flex items-center gap-4">
            <img
              id="current-avatar"
              src="/avatars/w_king_avatar.png"
              class="w-20 h-20 rounded-lg border shadow-sm"
            />

            <button
              id="openAvatarMenu"
              class="px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-black font-semibold rounded-lg transition cursor-pointer"
            >
              Cambiar avatar
            </button>
          </div>

          <!-- Panel lateral de avatares (CONTROLADO POR CSS GLOBAL) -->
          <div id="avatarMenu" class="hidden">
            <!-- JS insertará los avatares aquí -->
          </div>
        </div>

        <!-- Logout -->
        <button
          id="logoutBtn"
          class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition cursor-pointer"
        >
          Cerrar sesión
        </button>

      </div>

      <!-- COLUMNA DERECHA -->
      <div class="col-span-2 flex flex-col gap-6">

        <!-- Estadísticas generales -->
        <div class="bg-white dark:bg-[rgba(20,20,20,0.85)] dark:text-white p-5 rounded-xl shadow">
          <h3 class="font-semibold text-xl mb-3">Estadísticas generales</h3>
          <p id="stat-games"></p>
          <p id="stat-wins"></p>
          <p id="stat-losses"></p>
          <p id="stat-draws"></p>
        </div>

        <!-- Puzzles -->
        <div class="bg-white dark:bg-[rgba(20,20,20,0.85)] dark:text-white p-5 rounded-xl shadow">
          <h3 class="font-semibold text-xl mb-3">Puzzles</h3>

          <p id="stat-puzzles-solved"></p>
          <p id="stat-puzzles-failed"></p>

          <div class="mt-3">
            <p class="font-semibold">Progreso:</p>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
              <div id="puzzle-progress" class="bg-green-500 h-3 rounded-full"></div>
            </div>
          </div>
        </div>

        <!-- Fechas -->
        <div class="bg-white dark:bg-[rgba(20,20,20,0.85)] dark:text-white p-5 rounded-xl shadow">
          <h3 class="font-semibold text-xl mb-3">Actividad</h3>
          <p id="created-at"></p>
          <p id="last-login"></p>
        </div>

      </div>

    </div>
  </div>

  <script type="module" src="/src/scripts/profile.js"></script>

</BaseLayout>
