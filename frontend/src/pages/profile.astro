---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Perfil" bodyClass="perfil-page">

  <div class="min-h-screen pt-12 pb-24 px-6 sm:px-12 max-w-7xl mx-auto flex flex-col">
    
    <div id="profile-user" class="hidden flex-col gap-20">
      
      <header class="bg-black/30 backdrop-blur-xl border border-white/10 rounded-[3rem] p-12 md:py-20 md:px-16 shadow-2xl relative">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-yellow-600/10 blur-[150px] rounded-full"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-16">
          <div class="relative group">
            <div class="absolute -inset-4 bg-gradient-to-tr from-yellow-600 to-amber-400 rounded-[3rem] blur opacity-20 group-hover:opacity-40 transition duration-700"></div>
            <img id="current-avatar" src="/avatars/w_king_avatar.png" class="relative w-64 h-64 rounded-[2.5rem] border-2 border-yellow-500/20 object-cover shadow-2xl"/>
            <button id="openAvatarMenu" class="absolute -bottom-4 left-1/2 -translate-x-1/2 px-8 py-3 bg-yellow-500 hover:bg-yellow-400 text-black font-black rounded-2xl 
            text-xs uppercase shadow-2xl transition-transform hover:scale-110 whitespace-nowrap cursor-pointer">
              Cambiar Foto
            </button>

            <div id="avatarMenu" class="hidden"></div>
          </div>

          <div class="flex-1 space-y-10 text-center md:text-left">
            <div>
              <div class="flex flex-col md:flex-row md:items-center gap-6 mb-4">
                <h2 class="text-7xl md:text-8xl font-black text-white tracking-tighter" id="profile-username">---</h2>
                <span class="bg-yellow-500/10 border border-yellow-500/20 px-5 py-2 rounded-full text-yellow-500 text-xs font-black uppercase tracking-widest">Premium Member</span>
              </div>
              <p class="text-zinc-400 text-2xl font-medium italic" id="profile-email">---</p>
            </div>
            
            <div class="flex flex-wrap justify-center md:justify-start gap-12">
              <div class="flex flex-col gap-3">
                <span class="text-xs font-black text-zinc-500 uppercase tracking-[0.3em]">Tu Nivel Actual</span>
                <div class="bg-zinc-900/80 border border-white/5 px-10 py-6 rounded-[2rem] flex items-center gap-6">
                    <span class="text-6xl font-black text-white" id="stat-rating">0</span>
                    <span class="text-yellow-600 font-black text-xl uppercase">ELO</span>
                </div>
              </div>
              <div class="flex items-end pb-2">
                <button id="logoutBtn" class="px-10 py-6 bg-red-950/20 hover:bg-red-900/40 border border-red-900/30 text-red-400 rounded-3xl 
                transition-all text-xs font-black uppercase tracking-widest cursor-pointer">Cerrar Sesión</button>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main class="perfil-scroll grid grid-cols-1 lg:grid-cols-12 gap-16">
        
        <div class="lg:col-span-8 bg-zinc-900/20 border border-white/5 p-16 rounded-[4rem] shadow-xl">
          <h3 class="text-white font-black uppercase text-sm tracking-[0.5em] mb-20 flex items-center gap-6">
            <span class="w-12 h-[2px] bg-yellow-600"></span> ESTADÍSTICAS
          </h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
            <div class="space-y-4">
                <p class="text-zinc-500 text-xs font-black uppercase tracking-widest">Jugadas</p>
                <p id="stat-games" class="text-7xl font-black text-white tracking-tighter leading-none">0</p>
            </div>
            <div class="space-y-4">
                <p class="text-green-500/60 text-xs font-black uppercase tracking-widest">Victorias</p>
                <p id="stat-wins" class="text-7xl font-black text-green-400 leading-none">0</p>
            </div>
            <div class="space-y-4">
                <p class="text-red-500/60 text-xs font-black uppercase tracking-widest">Derrotas</p>
                <p id="stat-losses" class="text-7xl font-black text-red-400 leading-none">0</p>
            </div>
            <div class="space-y-4">
                <p class="text-blue-500/60 text-xs font-black uppercase tracking-widest">Tablas</p>
                <p id="stat-draws" class="text-7xl font-black text-blue-400 leading-none">0</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4 bg-zinc-900/20 border border-white/5 p-16 rounded-[4rem] flex flex-col justify-between shadow-xl">
          <div class="space-y-8">
            <h3 class="text-white font-black uppercase text-sm tracking-[0.5em]">Puzzles</h3>
            <p id="stat-puzzles-solved" class="text-8xl font-black text-white leading-none">0</p>
            <p id="stat-puzzles-failed" class="text-zinc-500 text-xs font-black uppercase">Fallos: 0</p>
          </div>
          <div class="space-y-6 pt-12">
            <div class="w-full bg-black/40 rounded-full h-4 p-1.5">
                <div id="puzzle-progress" class="bg-gradient-to-r from-yellow-600 to-yellow-400 h-full rounded-full shadow-[0_0_20px_rgba(234,179,8,0.4)]" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </main>

    </div>
  </div>

  <script type="module" src="/src/scripts/profile.js"></script>

</BaseLayout>
