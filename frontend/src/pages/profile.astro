---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileForm from "../components/ProfileForm";
---

<BaseLayout title="Perfil de Maestro | WELIKECHESS">
  <div class="h-[calc(100vh-80px)] w-full flex flex-col justify-end pb-10 relative overflow-hidden bg-[#050505]">
    
    {/* LUCES DE FONDO AMBIENTALES */}
    <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-[#d4af37]/5 rounded-full blur-[160px]"></div>
    <div class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-[#d4af37]/5 rounded-full blur-[160px]"></div>

    {/* HEADER TÉCNICO */}
    <div class="max-w-[1800px] mx-auto w-full px-14 py-4 flex justify-between items-center opacity-30 select-none pointer-events-none">
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 bg-yellow-500 rounded-full animate-pulse shadow-[0_0_8px_#eab308]"></div>
          <span class="text-[9px] text-white tracking-[0.5em] font-bold uppercase">Estado: Gran Maestro</span>
        </div>
        <span class="text-white opacity-20 text-[9px]">|</span>
        <span class="text-[9px] text-white tracking-[0.5em] font-light uppercase italic">User_Analytics_v3.4</span>
      </div>
      
      <div class="flex items-center gap-8">
        <span class="text-[9px] text-white tracking-[0.5em] font-light uppercase">ELO Promedio: 2400</span>
        <span class="text-[9px] text-white tracking-[0.5em] font-bold uppercase">Servidor: Chess_Main_Node</span>
      </div>
    </div>

    {/* COMPONENTE REACT */}
    <ProfileForm client:load />

  </div>
</BaseLayout>

<style is:global>
  body { overflow: hidden !important; }
  .custom-scrollbar::-webkit-scrollbar { display: none; }
</style>