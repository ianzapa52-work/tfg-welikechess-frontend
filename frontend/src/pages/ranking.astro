---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Ranking Global">

  <div class="max-w-7xl mx-auto px-6 py-16">

    <h1
      class="text-6xl md:text-7xl font-black mb-16 text-center
             bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
             bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      Ranking Global
    </h1>

    <div id="ranking-container" class="ranking-panel">
      <div id="loadingRanking" class="flex flex-col items-center justify-center py-20 gap-4">
        <div class="w-12 h-12 border-4 border-yellow-600/20 border-t-yellow-500 rounded-full animate-spin"></div>
        <p class="text-gray-400 text-lg italic tracking-widest uppercase animate-pulse">
          Cargando Maestros...
        </p>
      </div>
    </div>

  </div>

  <script>
    import "../scripts/ranking.js";
  </script>

</BaseLayout>

<style>
  .ranking-panel {
    background: rgba(10, 10, 10, 0.9);
    border: 2px solid rgba(212, 175, 55, 0.4);
    border-radius: 40px;
    padding: 3rem;
    backdrop-filter: blur(20px);
    max-width: 1150px;
    margin: 0 auto;
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.9);
  }

  /* Enlace contenedor */
  :global(.ranking-link) {
    text-decoration: none;
    display: block;
    margin-bottom: 1.5rem;
  }

  :global(.ranking-row) {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 2rem 3rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(212, 175, 55, 0.15);
    border-radius: 35px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }

  :global(.ranking-link:hover .ranking-row) {
    transform: scale(1.02) translateX(15px);
    background: rgba(212, 175, 55, 0.12);
    border-color: #ffd700;
  }

  /* --- POSICIÓN Y MEDALLAS --- */
  :global(.rank-position-wrapper) {
    min-width: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  :global(.rank-medal-img) {
    width: 85px; /* Medallas imponentes */
    height: auto;
    filter: drop-shadow(0 6px 12px rgba(0,0,0,0.6));
  }

  :global(.rank-number) {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: 1.4rem;
    color: #555;
    margin-top: 5px;
  }

  /* --- AVATARES Y BANDERAS (VERSION AGRANDADA) --- */
  :global(.rank-visuals) {
    position: relative;
    display: flex;
    align-items: center;
  }

  :global(.rank-avatar) {
    width: 100px;
    height: 100px;
    border-radius: 24px;
    border: 3px solid rgba(255,255,255,0.1);
    object-fit: cover;
    box-shadow: 0 8px 16px rgba(0,0,0,0.5);
  }

  /* Bandera: Más grande y prominente */
  :global(.flag-wrapper) {
    position: absolute;
    bottom: -2px; /* Un poco más hacia afuera para que resalte */
    right: -2px;
    width: 38px;  /* Aumentado de 28px */
    height: 26px; /* Proporción ajustada */
    overflow: hidden;
    border-radius: 6px;
    border: 2.5px solid #111; /* Borde un poco más grueso para contraste */
    box-shadow: 0 4px 8px rgba(0,0,0,0.9);
    background: #000;
  }

  :global(.rank-flag) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Ajustes Top 1 */
  :global(.rank-1 .rank-avatar) { 
    width: 130px; 
    height: 130px; 
    border-color: #ffd700; 
    border-width: 4px; 
  }
  
  :global(.rank-1 .rank-medal-img) { 
    width: 100px; 
  }
  
  :global(.rank-1 .rank-number) { 
    color: #ffd700; 
    font-size: 2rem; 
  }

  /* Ajustes Top 2 y 3 */
  :global(.rank-2 .rank-avatar, .rank-3 .rank-avatar) { 
    width: 115px; 
    height: 115px; 
  }
  
  :global(.rank-2 .flag-wrapper, .rank-3 .flag-wrapper) {
    width: 40px;
    height: 28px;
  }

  /* --- INFORMACIÓN --- */
  :global(.rank-info) { flex-grow: 1; }
  :global(.rank-name) { font-family: 'Cinzel', serif; font-size: 2.2rem; font-weight: 800; color: white; }
  :global(.rank-tier) {
    font-size: 0.8rem; padding: 4px 14px; border-radius: 8px;
    background: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3);
    color: #d4af37; font-weight: 900; letter-spacing: 2px;
    margin-left: 15px;
  }
  :global(.rank-stats) { color: #888; font-size: 1rem; display: flex; gap: 12px; margin-top: 8px; }

  /* --- CAJA DE ELO --- */
  :global(.rank-elo-box) {
    background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%);
    padding: 18px 35px; border-radius: 25px;
    border: 1px solid rgba(212, 175, 55, 0.4); text-align: center; min-width: 160px;
  }
  :global(.rank-elo-val) { display: block; color: #ffd700; font-weight: 900; font-size: 2.6rem; line-height: 1; font-family: 'Cinzel', serif; }
  :global(.rank-elo-label) { font-size: 0.75rem; color: #555; letter-spacing: 3px; margin-top: 6px; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  :global(.ranking-link) { animation: slideIn 0.6s ease-out forwards; }
</style>