---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Ranking Global">

  <div class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-16">

    <h1
      class="text-4xl md:text-7xl font-black mb-8 md:mb-16 text-center
             bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
             bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      Ranking Global
    </h1>

    <div id="ranking-container" class="ranking-panel">
      <div id="loadingRanking" class="flex flex-col items-center justify-center py-10 md:py-20 gap-4">
        <div class="w-10 h-10 md:w-12 md:h-12 border-4 border-yellow-600/20 border-t-yellow-500 rounded-full animate-spin"></div>
        <p class="text-gray-400 text-sm md:text-lg italic tracking-widest uppercase animate-pulse text-center">
          Cargando Maestros...
        </p>
      </div>
    </div>

  </div>

  <script>
    import "../scripts/ranking.js";
  </script>

</BaseLayout>

<style>
  /* --- PANEL PRINCIPAL --- */
  .ranking-panel {
    background: rgba(10, 10, 10, 0.9);
    border: 2px solid rgba(212, 175, 55, 0.4);
    border-radius: 24px; /* Más pequeño en general */
    padding: 1rem;      /* Móvil por defecto */
    backdrop-filter: blur(20px);
    max-width: 1150px;
    margin: 0 auto;
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.9);
  }

  @media (min-width: 768px) {
    .ranking-panel {
      border-radius: 40px;
      padding: 3rem;
    }
  }

  /* --- FILAS DEL RANKING --- */
  :global(.ranking-link) {
    text-decoration: none;
    display: block;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 768px) {
    :global(.ranking-link) { margin-bottom: 1.5rem; }
  }

  :global(.ranking-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;      /* Gap reducido para móvil */
    padding: 0.75rem;   /* Padding reducido para móvil */
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(212, 175, 55, 0.15);
    border-radius: 18px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    :global(.ranking-row) {
      gap: 2.5rem;
      padding: 2rem 3rem;
      border-radius: 35px;
    }
    :global(.ranking-link:hover .ranking-row) {
      transform: scale(1.02) translateX(15px);
      background: rgba(212, 175, 55, 0.12);
      border-color: #ffd700;
    }
  }

  /* --- POSICIÓN Y MEDALLAS --- */
  :global(.rank-position-wrapper) {
    min-width: 45px; /* Compacto en móvil */
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 768px) {
    :global(.rank-position-wrapper) { min-width: 120px; }
  }

  :global(.rank-medal-img) {
    width: 40px; 
    height: auto;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.6));
  }

  @media (min-width: 768px) {
    :global(.rank-medal-img) { width: 85px; }
  }

  :global(.rank-number) {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: 0.9rem;
    color: #666;
    margin-top: 2px;
  }

  @media (min-width: 768px) {
    :global(.rank-number) { font-size: 1.4rem; margin-top: 5px; }
  }

  /* --- AVATARES Y BANDERAS --- */
  :global(.rank-visuals) {
    position: relative;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  :global(.rank-avatar) {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    border: 2px solid rgba(255,255,255,0.1);
    object-fit: cover;
  }

  @media (min-width: 768px) {
    :global(.rank-avatar) {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      border-width: 3px;
    }
  }

  :global(.flag-wrapper) {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 20px;
    height: 14px;
    overflow: hidden;
    border-radius: 3px;
    border: 1.5px solid #111;
    background: #000;
  }

  @media (min-width: 768px) {
    :global(.flag-wrapper) {
      width: 38px;
      height: 26px;
      border-radius: 6px;
      border-width: 2.5px;
    }
  }

  /* --- AJUSTES TOP 1-2-3 MÓVIL --- */
  @media (max-width: 767px) {
    :global(.rank-1 .rank-avatar) { width: 65px; height: 65px; border-color: #ffd700; }
    :global(.rank-1 .rank-medal-img) { width: 50px; }
    :global(.rank-1 .rank-number) { color: #ffd700; font-size: 1.1rem; }
  }

  /* --- INFORMACIÓN --- */
  :global(.rank-info) { 
    flex-grow: 1; 
    min-width: 0; /* Evita que el texto rompa el flex */
  }

  :global(.rank-name) { 
    font-family: 'Cinzel', serif; 
    font-size: 1.1rem; 
    font-weight: 800; 
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.rank-tier) {
    font-size: 0.6rem; 
    padding: 2px 6px; 
    border-radius: 4px;
    background: rgba(212, 175, 55, 0.1); 
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: #d4af37; 
    font-weight: 900; 
    letter-spacing: 1px;
    display: inline-block;
    margin-top: 2px;
  }

  @media (min-width: 768px) {
    :global(.rank-name) { font-size: 2.2rem; }
    :global(.rank-tier) {
      font-size: 0.8rem; padding: 4px 14px; border-radius: 8px;
      margin-left: 15px; margin-top: 0; letter-spacing: 2px;
    }
    :global(.rank-stats) { font-size: 1rem; margin-top: 8px; }
  }

  :global(.rank-stats) { color: #888; font-size: 0.75rem; display: flex; gap: 8px; margin-top: 4px; }

  /* --- CAJA DE ELO --- */
  :global(.rank-elo-box) {
    background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%);
    padding: 8px 12px; 
    border-radius: 12px;
    border: 1px solid rgba(212, 175, 55, 0.4); 
    text-align: center;
    min-width: 70px;
  }

  @media (min-width: 768px) {
    :global(.rank-elo-box) {
      padding: 18px 35px; border-radius: 25px; min-width: 160px;
    }
  }

  :global(.rank-elo-val) { 
    display: block; 
    color: #ffd700; 
    font-weight: 900; 
    font-size: 1.2rem; 
    line-height: 1; 
    font-family: 'Cinzel', serif; 
  }

  :global(.rank-elo-label) { font-size: 0.5rem; color: #555; letter-spacing: 1px; margin-top: 2px; }

  @media (min-width: 768px) {
    :global(.rank-elo-val) { font-size: 2.6rem; }
    :global(.rank-elo-label) { font-size: 0.75rem; letter-spacing: 3px; margin-top: 6px; }
  }

  /* Animación */
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  :global(.ranking-link) { animation: slideIn 0.5s ease-out forwards; }
</style>