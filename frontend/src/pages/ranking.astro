---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Ranking Global">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-4xl md:text-7xl font-black mb-8 text-center bg-gradient-to-b from-[#d4af37] to-[#996515] bg-clip-text text-transparent" style="font-family: 'Cinzel', serif;">
      Ranking Global
    </h1>

    <div id="ranking-container" class="ranking-panel">
      </div>
  </div>

  <script>
    import "../scripts/ranking.js";
  </script>
</BaseLayout>

<style is:global>
  .ranking-panel {
    background: rgba(10, 10, 10, 0.9);
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 20px;
    padding: 10px;
    max-width: 1000px;
    margin: 0 auto;
  }

  /* FILA DE RANKING OPTIMIZADA */
  .ranking-row {
    display: grid;
    grid-template-columns: 50px 50px 1fr 70px; /* Espacios definidos */
    align-items: center;
    gap: 12px;
    padding: 12px;
    margin-bottom: 8px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid rgba(212, 175, 55, 0.1);
  }

  @media (min-width: 768px) {
    .ranking-row {
      grid-template-columns: 100px 90px 1fr 140px;
      padding: 1.5rem;
      gap: 20px;
    }
  }

  .rank-avatar { width: 45px; height: 45px; border-radius: 8px; object-fit: cover; }
  @media (min-width: 768px) { .rank-avatar { width: 80px; height: 80px; } }

  .rank-name {
    font-family: 'Cinzel', serif;
    font-weight: bold;
    color: white;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rank-elo-val { color: #ffd700; font-weight: 900; font-family: 'Cinzel', serif; text-align: right; }
</style>