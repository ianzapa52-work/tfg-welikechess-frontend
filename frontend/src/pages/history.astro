---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Historial">
  <div class="max-w-5xl mx-auto px-4 pt-10 pb-16">
    <h1 class="text-3xl md:text-6xl font-black mb-8 text-center bg-gradient-to-b from-[#d4af37] to-[#996515] bg-clip-text text-transparent" style="font-family: 'Cinzel', serif;">
      HISTORIAL DE PARTIDAS
    </h1>

    <div id="history-container" class="history-panel">
      </div>
  </div>

  <script>
    import "../scripts/history.ts";
  </script>
</BaseLayout>

<style>
  .history-panel {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
    background: rgba(15, 15, 15, 0.95);
    border: 2px solid rgba(212, 175, 55, 0.3);
    border-radius: 20px;
    min-height: 500px;
  }

  /* TARJETAS DE HISTORIAL CORREGIDAS */
  :global(.history-card) {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
    display: grid;
    grid-template-columns: 60px 1fr 80px; /* Layout fijo para que nada se corte */
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(212, 175, 55, 0.1);
  }

  :global(.history-card img) {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  @media (max-width: 600px) {
    :global(.history-card) {
      grid-template-columns: 50px 1fr; /* Reajuste para pantallas muy estrechas */
      font-size: 0.8rem;
    }
  }
</style>