---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Historial">

  <div class="max-w-5xl mx-auto px-4 py-10">

    <h1
      class="text-5xl font-bold mb-10 text-center
             bg-linear-to-r from-[#5a3e1b] via-[#7a5528] to-[#4a2f14]
             bg-clip-text text-transparent drop-shadow-sm"
      style="font-family: 'Cinzel', serif;"
    >
      Historial de Partidas
    </h1>

    <div id="history-container" class="history-panel">

      <p id="loadingHistory"
        class="text-center text-gray-700 text-lg italic tracking-wide">
        Cargando historial...
      </p>

    </div>

  </div>

  <script type="module" src="/src/scripts/history.js"></script>

</BaseLayout>
