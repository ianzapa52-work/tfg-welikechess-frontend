---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Online Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel top-panel">
        <div class="player-box opponent-card">
          <div class="flex justify-between items-center mb-2">
            <div class="player-header !mb-0"><span>👤 RIVAL</span></div>
            <div id="game-status" class="status-badge">CONECTANDO...</div>
          </div>
          <div id="captured-white" class="mini-captured"></div>
        </div>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel bottom-panel">
        <div class="player-box user-card">
          <div class="player-header"><span>♔ TÚ</span></div>
          <div id="captured-black" class="mini-captured"></div>
        </div>

        <div class="history-card hidden md:block">
          <div class="history-header">MOVIMIENTOS</div>
          <div class="history-scroll">
            <table>
              <tbody id="move-body"></tbody>
            </table>
          </div>
        </div>
        
        <button id="resetBtn" class="gold-btn danger-btn">ABANDONAR</button>
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/play-online.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start; 
    padding: 10px;
    background: transparent;
  }

  /* Layout dinámico */
  .game-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 600px;
  }

  @media (min-width: 1200px) {
    .game-wrapper {
      display: grid;
      grid-template-columns: 240px 680px 240px; 
      max-width: 1200px;
      gap: 40px;
      align-items: start;
    }
    .main-screen { padding-top: 50px; }
  }

  .side-panel {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Estética Premium */
  .player-box, .history-card, .status-box {
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(212, 175, 55, 0.3);
    padding: 12px;
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }

  .player-header {
    font-family: 'Cinzel', serif;
    color: #d4af37;
    font-size: 0.8rem;
    letter-spacing: 1px;
  }

  /* EL TABLERO RESPONSIVO */
  .board-frame {
    background: #1a1a1a;
    padding: 8px;
    border-radius: 4px;
    border: 3px solid #333;
    margin: 0 auto;
  }

  .compact-board {
    width: 88vw; 
    height: 88vw;
    max-width: 600px;
    max-height: 600px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
  }

  @media (min-width: 768px) {
    .board-frame { padding: 20px; border-width: 4px; }
    .compact-board { width: 600px; height: 600px; }
  }

  .square { 
    width: 100%; 
    height: 100%; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
  }
  
  .square.light { background: #ebecd0; }
  .square.dark { background: #779556; }
  .square.selected { background: rgba(212, 175, 55, 0.5) !important; }

  /* Coordenadas adaptadas */
  .coords-h { display: flex; justify-content: space-around; padding-left: 18px; margin-bottom: 4px; color: #d4af37; font-size: 0.7rem; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 18px; color: #d4af37; font-size: 0.7rem; }
  .board-flex { display: flex; }

  /* Estado y Botones */
  .status-badge {
    color: #d4af37;
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    font-weight: bold;
    padding: 4px 8px;
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 4px;
  }
  
  .history-scroll { height: 150px; overflow-y: auto; font-size: 0.8rem; color: #eee; }

  .gold-btn {
    background: transparent;
    border: 1px solid #d4af37;
    color: #d4af37;
    padding: 10px;
    cursor: pointer;
    font-family: 'Cinzel';
    font-size: 0.8rem;
    font-weight: bold;
    transition: 0.3s;
  }

  .danger-btn:hover {
    background: #7f1d1d;
    border-color: #ef4444;
    color: white;
  }

  .piece { 
    width: 90%; 
    height: 90%; 
    filter: drop-shadow(2px 2px 2px rgba(0,0,0,0.4)); 
  }
  
  .mini-captured { display: flex; flex-wrap: wrap; gap: 2px; min-height: 15px; margin-top: 5px; }
</style>