---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/chessboard.css";
---

<BaseLayout title="WELIKECHESS - Jugar Online">

  <div class="game-layout">
    <div class="game-status">
      <p id="game-status" class="text-lg font-semibold bg-white shadow px-3 py-2 rounded-md">
        Turno de las blancas
      </p>
    </div>

    <div class="board-wrapper">
      <div class="coords-top">
        <span>A</span><span>B</span><span>C</span><span>D</span>
        <span>E</span><span>F</span><span>G</span><span>H</span>
      </div>

      <div class="coords-left">
        <span>8</span><span>7</span><span>6</span><span>5</span>
        <span>4</span><span>3</span><span>2</span><span>1</span>
      </div>

      <div id="board" class="board"></div>

      <div id="captured-area" class="mt-4 flex justify-between">
        <div id="captured-white" class="flex flex-wrap gap-1"></div>
        <div id="captured-black" class="flex flex-wrap gap-1"></div>
      </div>
    </div>

    <div class="move-history">
      <h2 class="text-xl font-bold mb-2">Historial</h2>
      <table class="text-sm border-collapse w-full">
        <thead>
          <tr><th>#</th><th>Blancas</th><th>Negras</th></tr>
        </thead>
        <tbody id="move-body"></tbody>
      </table>
    </div>
  </div>

  <script type="module" src="/src/scripts/play-online.js"></script>

</BaseLayout>

<style>
  .game-layout {
    display: grid;
    grid-template-columns: 1fr auto 300px;
    gap: 2rem;
    padding: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    align-items: start;
  }

  /* El contenedor del tablero con coordenadas */
  .board-wrapper {
    position: relative;
    padding: 25px;
    background: var(--bg-panel);
    border: 2px solid var(--border-panel);
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  /* Estilos para las coordenadas */
  .coords-top, .coords-left {
    display: flex;
    justify-content: space-around;
    color: var(--color-gold);
    font-weight: bold;
    font-family: 'Cinzel', serif;
    opacity: 0.8;
  }
  .coords-top { margin-bottom: 10px; }
  .coords-left {
    position: absolute;
    left: 0;
    top: 25px;
    height: calc(100% - 50px);
    flex-direction: column;
    padding-left: 5px;
  }

  .game-status p {
    background: var(--bg-card) !important;
    color: var(--text-main);
    border: 1px solid var(--border-panel);
  }

  .move-history {
    background: var(--bg-panel);
    border: 1px solid var(--border-panel);
    border-radius: 12px;
    padding: 1.5rem;
    height: 600px;
    overflow-y: auto;
    color: var(--text-main);
  }

  @media (max-width: 1100px) {
    .game-layout { grid-template-columns: 1fr; justify-items: center; }
    .move-history { width: 100%; height: 300px; }
  }
</style>