---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Inicio de sesión">

  <div class="h-[calc(100vh-4rem)] flex flex-col items-center justify-center -translate-y-17.5">

    <div class="flex justify-center mb-4">
      <img
        id="kingIcon"
        src="/pieces/w_king.svg"
        alt="Logo"
        class="w-16 opacity-90 cursor-pointer transition-all duration-300"
      />
    </div>

    <!-- TARJETA LOGIN -->
    <div
      id="loginCard"
      class="login-card w-95 p-8 rounded-xl shadow-lg transition-all duration-300
             bg-white text-black
             dark:bg-[rgba(20,20,20,0.85)]
             dark:border dark:border-[#d4af37]
             dark:text-white"
    >

      <h1 class="text-3xl font-bold mb-6 text-center dark:text-white" style="font-family: 'Cinzel', serif;">
        Inicio de sesión
      </h1>

      <form id="loginForm" class="flex flex-col gap-4">

        <!-- Email -->
        <div>
          <label class="block mb-1 font-medium dark:text-white">Email</label>
          <input
            id="loginEmail"
            type="email"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 text-black
                   focus:ring-2 focus:outline-none
                   dark:bg-[rgba(255,255,255,0.08)]
                   dark:border-[#d4af37]
                   dark:text-white dark:placeholder-gray-300"
            required
          />
        </div>

        <!-- Contraseña -->
        <div>
          <label class="block mb-1 font-medium dark:text-white">Contraseña</label>
          <input
            id="loginPassword"
            type="password"
            class="w-full px-4 py-2 rounded-lg border border-gray-300 text-black
                   focus:ring-2 focus:outline-none
                   dark:bg-[rgba(255,255,255,0.08)]
                   dark:border-[#d4af37]
                   dark:text-white dark:placeholder-gray-300"
            required
          />
        </div>

        <!-- Botón -->
        <button
          type="submit"
          class="w-full py-2 rounded-lg font-semibold transition cursor-pointer
                 bg-blue-600 hover:bg-blue-700 text-white
                 dark:bg-linear-to-br dark:from-[#d4af37] dark:to-[#f5d67b]
                 dark:text-black"
        >
          Iniciar sesión
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-4 dark:text-gray-300">
        ¿No tienes cuenta?
        <a href="/register" class="text-blue-600 hover:underline dark:text-[#f5d67b]">Regístrate</a>
      </p>
    </div>
  </div>

  <script type="module" src="/src/scripts/login.js"></script>

</BaseLayout>

<style>
  .login-card {
    max-width: 420px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }

  input {
    transition: all 0.3s ease;
  }

  input:focus {
    border-color: var(--color-gold) !important;
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2);
  }

  /* El botón ya hereda las clases globales .home-btn, pero podemos darle un toque extra */
  button[type="submit"] {
    letter-spacing: 1px;
    text-transform: uppercase;
    font-family: 'Cinzel', serif;
  }
</style>