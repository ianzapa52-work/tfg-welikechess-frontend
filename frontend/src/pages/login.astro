---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Inicio de sesión">

  <div class="min-h-[calc(100vh-8rem)] flex flex-col items-center justify-center px-4 py-8 md:-translate-y-10">

    <div class="flex justify-center mb-6">
      <img
        id="kingIcon"
        src="/pieces/w_king.svg"
        alt="Logo"
        class="w-14 md:w-16 opacity-90 cursor-pointer transition-all duration-300"
      />
    </div>

    <div
      id="loginCard"
      class="login-card w-full max-w-[400px] p-6 md:p-8 rounded-xl shadow-lg transition-all duration-300
             bg-white text-black
             dark:bg-[rgba(20,20,20,0.85)]
             dark:border dark:border-[#d4af37]
             dark:text-white"
    >

      <h1 class="text-2xl md:text-3xl font-bold mb-6 text-center dark:text-white" style="font-family: 'Cinzel', serif;">
        Inicio de sesión
      </h1>

      <form id="loginForm" class="flex flex-col gap-5">

        <div class="flex flex-col gap-1">
          <label class="block text-sm font-medium dark:text-white">Email</label>
          <input
            id="loginEmail"
            type="email"
            placeholder="tu@email.com"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-black text-base
                   focus:ring-2 focus:outline-none
                   dark:bg-[rgba(255,255,255,0.08)]
                   dark:border-[#d4af37]
                   dark:text-white dark:placeholder-gray-500"
            required
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="block text-sm font-medium dark:text-white">Contraseña</label>
          <input
            id="loginPassword"
            type="password"
            placeholder="••••••••"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-black text-base
                   focus:ring-2 focus:outline-none
                   dark:bg-[rgba(255,255,255,0.08)]
                   dark:border-[#d4af37]
                   dark:text-white dark:placeholder-gray-500"
            required
          />
        </div>

        <button
          type="submit"
          class="w-full py-3 mt-2 rounded-lg font-semibold transition cursor-pointer text-sm md:text-base
                 bg-blue-600 hover:bg-blue-700 text-white
                 dark:bg-gradient-to-br dark:from-[#d4af37] dark:to-[#f5d67b]
                 dark:text-black uppercase tracking-wider"
          style="font-family: 'Cinzel', serif;"
        >
          Entrar
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-6 dark:text-gray-300">
        ¿No tienes cuenta?
        <a href="/register" class="text-blue-600 font-bold hover:underline dark:text-[#f5d67b]">Regístrate</a>
      </p>
    </div>
  </div>

  <script>
    import "../scripts/login.ts";
  </script>

</BaseLayout>

<style>
  .login-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  input {
    transition: all 0.3s ease;
    /* Evita que el zoom automático de iOS rompa el layout */
    font-size: 16px !important; 
  }

  input:focus {
    border-color: #d4af37 !important;
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2);
  }

  /* Ajuste para que el formulario no se pegue al techo en móviles muy pequeños */
  @media (max-height: 600px) {
    .md\:-translate-y-10 {
      transform: translateY(0);
    }
  }
</style>